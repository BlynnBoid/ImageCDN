# ── Server ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
# Base URL of this server — used to build image URLs in local storage mode
PUBLIC_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/imagecdn

# When routing through PgBouncer, point DATABASE_URL at the bouncer port instead:
# DATABASE_URL=postgresql://user:password@localhost:6432/imagecdn

# Max connections this app instance opens (to PgBouncer or directly to Postgres).
# With PgBouncer: can be high (20-50); PgBouncer multiplexes to the DB limit.
# Direct to Postgres with 5-connection limit and 3 instances: set to 1.
DB_POOL_MAX=10

# ── Auth ─────────────────────────────────────────────────
# Static token protecting the /admin panel only
# Upload auth uses per-user API keys generated via the admin panel
ADMIN_TOKEN=replace-with-a-long-random-string

# ── Upload limits ────────────────────────────────────────
MAX_FILE_SIZE_MB=25

# ── Storage ──────────────────────────────────────────────
# local: mount UPLOAD_DIR on persistent storage in production
# s3: required for multiple app replicas unless they share a filesystem
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# ── S3-compatible storage (optional) ─────────────────────
# Set STORAGE_PROVIDER=s3 and configure all four required S3 values
#
# S3_ENDPOINT=https://s3.yourprovider.com
# S3_REGION=auto
# S3_BUCKET=images
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# ── Cloudflare cache purging (optional, Enterprise only) ──
# Enables instant cache invalidation on image delete via Cache-Tag purge
# Without these, deleted images expire from CDN cache naturally via TTL
#
# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_API_TOKEN=your-cf-api-token

# ── Multi-region (optional) ───────────────────────────────
# Used by GET /api/region on the main gateway domain to return the nearest
# upload URL to clients based on their Cloudflare country header.
# Leave unset to use the defaults below.
#
# REGION_NA1_URL=https://na1.frogcdn.com
# REGION_EU1_URL=https://eu1.frogcdn.com
# REGION_EU2_URL=https://eu2.frogcdn.com
