# ── Server ───────────────────────────────────────────────
PORT=3000
# Base URL of this server — used to build image URLs in local storage mode
PUBLIC_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/imagecdn

# ── Auth ─────────────────────────────────────────────────
# Static token protecting the /admin panel only
# Upload auth uses per-user API keys generated via the admin panel
ADMIN_TOKEN=replace-with-a-long-random-string

# ── Upload limits ────────────────────────────────────────
MAX_FILE_SIZE_MB=25

# ── S3-compatible storage (optional) ─────────────────────
# Leave ALL S3_ vars unset to fall back to local ./uploads/ folder
#
# S3_ENDPOINT=https://s3.yourprovider.com
# S3_REGION=auto
# S3_BUCKET=images
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# ── Cloudflare cache purging (optional, Enterprise only) ──
# Enables instant cache invalidation on image delete via Cache-Tag purge
# Without these, deleted images expire from CDN cache naturally via TTL
#
# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_API_TOKEN=your-cf-api-token
