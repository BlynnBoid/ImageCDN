{
  "name": "imagecdn",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.18",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "start:deploy": "bun run db:migrate && bun run start",
    "typecheck": "bun x tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@hono/zod-validator": "^0.5.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.7.11",
    "nanoid": "^5.1.5",
    "pino": "^9.7.0",
    "postgres": "^3.4.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "bun-types": "^1.2.18",
    "drizzle-kit": "^0.31.1",
    "typescript": "5.8.3"
  }
}
